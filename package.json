{
  "name": "@graphile-contrib/pg-order-by-related",
  "version": "2.0.0-rc.1",
  "description": "Order by related columns on PostGraphile connections",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "format": "prettier --ignore-path ./.lintignore",
    "format:all": "yarn format '**/*.{json,md,html,js,jsx,ts,tsx}'",
    "format:fix": "yarn format:all --write",
    "format:check": "yarn format:all --list-different",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "prepack": "tsc -p tsconfig.build.json",
    "test": "tsc -p tsconfig.build.json && scripts/test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/graphile-contrib/pg-order-by-related.git"
  },
  "author": "Matt Bretl",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/graphile-contrib/pg-order-by-related/issues"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.0",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.39.1",
    "@tsconfig/node18": "^18.2.4",
    "@typescript-eslint/parser": "^8.47.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-graphile-export": "^1.0.0-rc.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^28.14.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-tsdoc": "^0.5.0",
    "eslint_d": "^14.3.0",
    "jest": "29.3.1",
    "pg": "8.8.0",
    "postgraphile": "^5.0.0-rc.9",
    "prettier": "2.8.0",
    "typescript": "^5.7.2"
  },
  "jest": {
    "testRegex": "__tests__/.*\\.test\\.js$"
  },
  "files": [
    "dist"
  ]
}
